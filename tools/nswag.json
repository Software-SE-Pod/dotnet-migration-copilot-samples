{
  "swaggerGenerator": {
    "fromSwagger": {
      "url": "../contracts/openapi.yaml"
    }
  },
  "codeGenerators": {
    "openApiToCSharpClient": {
      "className": "ApiClient",
      "namespace": "ApiContracts.Generated",
      "output": "../dotnet/ApiContracts/Generated/ApiClient.cs"
    },
    "openApiToTypeScriptClient": {
      "output": "../web/src/api/generated/api-client.ts"
    }
  }
}
