{
  "runtime": "Net100",
  "documentGenerator": {
    "fromSwagger": {
      "url": "../contracts/openapi.yaml"
    }
  },
  "codeGenerators": {
    "swaggerToCSharpClient": {
      "className": "ApiContractsClient",
      "namespace": "ApiContracts.Generated",
      "output": "../dotnet/ApiContracts/Generated/ApiContracts.cs"
    },
    "swaggerToTypeScriptClient": {
      "output": "../web/src/api/generated/index.ts"
    }
  }
}
